# Copie para .env na raiz (usado pelo Docker Compose)
# cp .env.example .env

POSTGRES_USER=einvoice
POSTGRES_PASSWORD=einvoice
POSTGRES_DB=e_invoice_play
POSTGRES_PORT=5432

# Mesma URL em backend/.env para Prisma e a API local
DATABASE_URL=postgresql://einvoice:einvoice@localhost:5432/e_invoice_play?schema=public
