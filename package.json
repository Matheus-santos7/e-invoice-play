{
  "name": "e-invoice-play",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,magenta \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:frontend": "pnpm --filter @e-invoice-play/frontend dev",
    "dev:backend": "pnpm --filter @e-invoice-play/backend dev",
    "build": "pnpm --filter @e-invoice-play/frontend build && pnpm --filter @e-invoice-play/backend build",
    "start:frontend": "pnpm --filter @e-invoice-play/frontend start",
    "start:backend": "pnpm --filter @e-invoice-play/backend start",
    "lint": "pnpm --filter @e-invoice-play/frontend lint",
    "format": "prettier --write .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f postgres",
    "docker:reset": "docker compose down -v",
    "db:setup": "pnpm docker:up && pnpm --filter @e-invoice-play/backend db:migrate:deploy && pnpm --filter @e-invoice-play/backend db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.7.3"
  }
}
